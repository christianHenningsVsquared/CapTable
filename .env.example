# Copy to .env and fill in. Never commit the real .env (see .gitignore).

# Required for the live LLM extraction (extractContract). Tests mock the client,
# so this is only needed to run the gated live test or the real app.
ANTHROPIC_API_KEY=

# Optional: override the extraction model (defaults to claude-opus-4-7).
# EXTRACTION_MODEL=claude-opus-4-7

# Copy to .env (or use `captable config set`) and fill in. Never commit the real
# .env (see .gitignore). The CLI resolves config from flags → env → file.

# Provider selection (one of: anthropic, openai)
# CAPTABLE_PROVIDER=anthropic

# Anthropic key (required when CAPTABLE_PROVIDER=anthropic, or when no provider
# is set and you want Anthropic to be picked automatically).
ANTHROPIC_API_KEY=

# OpenAI key (required when CAPTABLE_PROVIDER=openai).
# OPENAI_API_KEY=

# Optional model override. Defaults: claude-opus-4-7 (anthropic), gpt-4o (openai).
# CAPTABLE_MODEL=

{
  "name": "captable",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "VC cap-table tool — MVP headless CLI (Streams A + B)",
  "bin": {
    "captable": "dist/cli/index.js"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "cli": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.0",
    "@ai-sdk/openai": "^2.0.0",
    "ai": "^5.0.0",
    "better-sqlite3": "^12.10.0",
    "commander": "^14.0.0",
    "decimal.js": "^10.6.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "tsx": "^4.20.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}

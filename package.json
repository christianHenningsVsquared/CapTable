{
  "name": "captable",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "VC cap-table tool — MVP headless CLI (Streams A + B)",
  "license": "MIT",
  "bin": {
    "captable": "dist/cli/index.js"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "cli": "tsx src/cli/index.ts",
    "server": "tsx src/server/index.ts",
    "server:watch": "tsx watch src/server/index.ts",
    "web": "vite src/web",
    "dev": "concurrently -n server,web -c blue,magenta \"npm:server:watch\" \"npm:web\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.0",
    "@ai-sdk/openai": "^2.0.0",
    "@tanstack/react-query": "^5.100.13",
    "ai": "^5.0.0",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^14.0.0",
    "cors": "^2.8.6",
    "decimal.js": "^10.6.0",
    "express": "^5.2.1",
    "lucide-react": "^1.16.0",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "xlsx": "^0.18.5",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.20.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
